# ════════════════════════════════════════════════════════
#  Nexus Panel — Environment Variables
#  Copy this file to .env.local and fill in the values
# ════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Storage (Supabase Storage by default) ─────────────
# Bucket name must be created in Supabase Dashboard → Storage
# Set to PUBLIC bucket named "nexus-mods"
# NEXUS_BUCKET=nexus-mods  (set in lib/storage.ts)

# ── Optional: Cloudflare R2 (swap lib/storage.ts to use) ──
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ── App ───────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
